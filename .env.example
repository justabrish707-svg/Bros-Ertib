# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# TELEGRAM_BOT_TOKEN: The token for your Telegram bot (from @BotFather).
TELEGRAM_BOT_TOKEN=8788398386:AAFttkEIIX1JFqywvv48Qnh17Jfmp9CNuJ8

# TELEGRAM_CHAT_ID: The ID of the chat where notifications should be sent.
TELEGRAM_CHAT_ID=5803816508

# APP_URL: The URL of your deployed backend (Railway, Render, etc.).
APP_URL="http://localhost:3000"

# VITE_API_URL: The base URL for API requests from the frontend.
# Set this to your Railway/Render backend URL when deploying to Vercel.
# Leave empty for local development (frontend + backend on same server).
VITE_API_URL=""

# STRIPE_SECRET_KEY: Your Stripe secret key (sk_test_...).
STRIPE_SECRET_KEY=

# VITE_STRIPE_PUBLISHABLE_KEY: Your Stripe publishable key (pk_test_...).
VITE_STRIPE_PUBLISHABLE_KEY=

# CHAPA_SECRET_KEY: Your Chapa secret key (CHASECK_TEST-...).
CHAPA_SECRET_KEY=

