# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="your_gemini_api_key_here"

# TELEGRAM_BOT_TOKEN: The token for your Telegram bot (from @BotFather).
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# TELEGRAM_CHAT_ID: The ID of the chat where notifications should be sent.
TELEGRAM_CHAT_ID="your_telegram_chat_id_here"

# APP_URL: The URL of your deployed backend (Railway, Render, etc.).
APP_URL="http://localhost:3000"

# VITE_API_URL: The base URL for API requests from the frontend.
VITE_API_URL=""

# STRIPE_SECRET_KEY: Your Stripe secret key (sk_test_...).
STRIPE_SECRET_KEY="your_stripe_secret_key_here"

# VITE_STRIPE_PUBLISHABLE_KEY: Your Stripe publishable key (pk_test_...).
VITE_STRIPE_PUBLISHABLE_KEY="your_stripe_publishable_key_here"

# STRIPE_WEBHOOK_SECRET: Your Stripe webhook secret (whsec_...).
STRIPE_WEBHOOK_SECRET="your_stripe_webhook_secret_here"

# CHAPA_SECRET_KEY: Your Chapa secret key (CHASECK_TEST-...).
CHAPA_SECRET_KEY="your_chapa_secret_key_here"

# FIREBASE_SERVICE_ACCOUNT_KEY: JSON string of your Firebase service account key.
FIREBASE_SERVICE_ACCOUNT_KEY='{"type": "service_account", ...}'

# PORT: The port the server should run on (default: 3000).
PORT=3000

